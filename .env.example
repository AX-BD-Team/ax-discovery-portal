# =============================================================================
# AX Discovery Portal - Environment Variables
# =============================================================================

# -----------------------------------------------------------------------------
# Anthropic API
# -----------------------------------------------------------------------------
ANTHROPIC_API_KEY=sk-ant-xxx

# Agent 모델 설정
AGENT_MODEL=claude-sonnet-4-20250514

# -----------------------------------------------------------------------------
# Confluence
# -----------------------------------------------------------------------------
CONFLUENCE_BASE_URL=https://your-domain.atlassian.net
CONFLUENCE_API_TOKEN=your-api-token
CONFLUENCE_USER_EMAIL=your-email@example.com
CONFLUENCE_SPACE_KEY=AXBD

# Confluence 페이지 ID (Confluence에서 확인)
# 예: https://your-domain.atlassian.net/wiki/spaces/AXBD/pages/123456789
# → CONFLUENCE_PLAY_DB_PAGE_ID=123456789
# Action Log 페이지: Activity 기록을 추가할 페이지 ID
CONFLUENCE_ACTION_LOG_PAGE_ID=
# Play DB 페이지: Play 진행현황 테이블이 있는 페이지 ID
CONFLUENCE_PLAY_DB_PAGE_ID=

# (구버전 - 사용 안 함)
CONFLUENCE_PLAY_DB_ID=
CONFLUENCE_ACTION_LOG_DB_ID=

# -----------------------------------------------------------------------------
# Database - Cloudflare D1 (SQLite)
# -----------------------------------------------------------------------------
# D1 데이터베이스 생성 후 설정:
# npx wrangler d1 create ax-discovery-db
CLOUDFLARE_ACCOUNT_ID=your-account-id
CLOUDFLARE_API_TOKEN=your-api-token
D1_DATABASE_ID=your-database-id

# (Legacy - PostgreSQL, 현재 미사용)
# DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/ax_discovery

# -----------------------------------------------------------------------------
# Teams Integration (Optional)
# -----------------------------------------------------------------------------
TEAMS_WEBHOOK_URL=

# -----------------------------------------------------------------------------
# Application
# -----------------------------------------------------------------------------
APP_ENV=development
DEBUG=true
LOG_LEVEL=INFO

# API Server
API_HOST=0.0.0.0
API_PORT=8000

# CORS
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# -----------------------------------------------------------------------------
# Security
# -----------------------------------------------------------------------------
# JWT Secret (for API authentication)
JWT_SECRET=your-secret-key

# Approval timeout (seconds)
APPROVAL_TIMEOUT=86400
